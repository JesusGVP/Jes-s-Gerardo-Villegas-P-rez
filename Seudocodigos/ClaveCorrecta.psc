Algoritmo ContraseńaCorrecta
	Definir clave_correcta, intento Como Cadena
    clave_correcta <- "hellwaheela" 
    Escribir "Ingrese su contraseńa:"
    Leer intento
    Mientras intento<>clave_correcta Hacer
        Escribir "Contraseńa incorrecta. Intente de nuevo:"
        Leer intento
	FinMientras
	Escribir "ˇAcceso concedido!"
FinAlgoritmo